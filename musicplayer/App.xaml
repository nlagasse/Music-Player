<Application x:Class="musicplayer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:musicplayer"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             StartupUri="MainWindow.xaml">

    <Application.Resources>

        <!-- Gray Boxes -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#0f1012"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Padding" Value="10"/>
        </Style>

        <!-- Music Selection -->
        <Style x:Key="MusicListViewItemStyle" TargetType="ListViewItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,4,0,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="0">

                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder"
                                        Property="Background"
                                        Value="#17181A"/>
                            </Trigger>

                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder"
                                        Property="Background"
                                        Value="#2A2B2E"/>
                            </Trigger>

                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ItemBorder"
                                        Property="Background"
                                        Value="#2A2B2E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Buttons -->
        <Style x:Key="PlayerButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="#202124"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="#2A2B2E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Default Thumb Circle -->
        <Style TargetType="{x:Type primitives:Thumb}">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type primitives:Thumb}">
                        <Ellipse Fill="White"
                                 Stroke="#DDDDDD"
                                 StrokeThickness="1"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Green Colors -->
        <SolidColorBrush x:Key="GreenIdleBrush" Color="#183333"/>
        <SolidColorBrush x:Key="GreenHoverBrush" Color="DarkSlateGray"/>
        <SolidColorBrush x:Key="GreenThumbBrush" Color="#254848"/>
        <SolidColorBrush x:Key="GreenThumbHoverBrush" Color="DarkSlateGray"/>

        <!-- Round Slider Thumb -->
        <Style x:Key="RoundSliderThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Ellipse x:Name="ThumbCircle"
                                 Fill="{StaticResource GreenIdleBrush}"
                                 Stroke="{StaticResource GreenHoverBrush}"
                                 StrokeThickness="1"/>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbCircle"
                                        Property="Fill"
                                        Value="{StaticResource GreenHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Green Horizontal Slider -->
        <Style x:Key="GreenHorizontalSliderStyle" TargetType="{x:Type Slider}">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Slider}">
                        <Grid Height="28"
                              Background="Transparent">

                            <!-- Full pill track -->
                            <Border x:Name="FullTrack"
                                    Height="6"
                                    CornerRadius="3"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Stretch"
                                    Background="{StaticResource GreenIdleBrush}"
                                    Margin="8,0,8,0"/>

                            <Track x:Name="PART_Track"
                                   VerticalAlignment="Center"
                                   IsDirectionReversed="False"
                                   Margin="8,0,8,0">

                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge"
                                                  Opacity="0"
                                                  Focusable="False"
                                                  IsTabStop="False"/>
                                </Track.DecreaseRepeatButton>

                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge"
                                                  Opacity="0"
                                                  Focusable="False"
                                                  IsTabStop="False"/>
                                </Track.IncreaseRepeatButton>

                                <Track.Thumb>
                                    <Thumb Style="{StaticResource RoundSliderThumbStyle}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FullTrack"
                                        Property="Background"
                                        Value="{StaticResource GreenHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Green Vertical Slider -->
        <Style x:Key="GreenVerticalSliderStyle" TargetType="{x:Type Slider}">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Slider}">
                        <Grid Width="28"
                              Background="Transparent">

                            <!-- Full pill track behind everything -->
                            <Border x:Name="FullTrack"
                                    Width="6"
                                    CornerRadius="3"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Stretch"
                                    Background="{StaticResource GreenIdleBrush}"
                                    Margin="0,10,0,10"/>

                            <Track x:Name="PART_Track"
                                   Orientation="Vertical"
                                   HorizontalAlignment="Center"
                                   IsDirectionReversed="False"
                                   Margin="0,10,0,10">

                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge"
                                                  Opacity="0"
                                                  Focusable="False"
                                                  IsTabStop="False"/>
                                </Track.DecreaseRepeatButton>

                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge"
                                                  Opacity="0"
                                                  Focusable="False"
                                                  IsTabStop="False"/>
                                </Track.IncreaseRepeatButton>

                                <Track.Thumb>
                                    <Thumb Style="{StaticResource RoundSliderThumbStyle}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FullTrack"
                                        Property="Background"
                                        Value="{StaticResource GreenHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Green ScrollBar Thumb -->
        <Style x:Key="GreenScrollBarThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="MinHeight" Value="44"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="ThumbBorder"
                        Width="8"
                        MinHeight="44"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Stretch"
                        Background="{StaticResource GreenIdleBrush}"/>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder"
                                Property="Background"
                                Value="{StaticResource GreenHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Invisible ScrollBar Repeat Button -->
        <Style x:Key="InvisibleScrollBarRepeatButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Green Vertical ScrollBar -->
        <Style x:Key="GreenVerticalScrollBarStyle" TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Background="Transparent"
                      Width="10">

                            <Track x:Name="PART_Track"
                           Orientation="Vertical"
                           IsDirectionReversed="True">

                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                          Style="{StaticResource InvisibleScrollBarRepeatButtonStyle}"/>
                                </Track.DecreaseRepeatButton>

                                <Track.Thumb>
                                    <Thumb MinHeight="44"
                                   Style="{StaticResource GreenScrollBarThumbStyle}"/>
                                </Track.Thumb>

                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                          Style="{StaticResource InvisibleScrollBarRepeatButtonStyle}"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Apply green scrollbar globally -->
        <Style TargetType="{x:Type ScrollBar}"
               BasedOn="{StaticResource GreenVerticalScrollBarStyle}"/>

    </Application.Resources>
</Application>