<UserControl x:Class="musicplayer.View.UserControls.AlbumGrid"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:musicplayer.View.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Border Style="{StaticResource CardStyle}">
        <Grid Background="Transparent" PreviewMouseLeftButtonDown="AlbumGridBackground_PreviewMouseLeftButtonDown">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <!-- Buttons -->
            <Grid Grid.Row="0" Background="Transparent">
                <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Margin="0">

                    <!-- Playlist Button -->
                    <Button Name="CreatePlaylistButton"
                        Width="Auto"
                        Height="40"
                        Padding="10,4"
                        Margin="0,0,8,0"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="CreatePlaylistButton_Click">

                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>

                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="ButtonBorder"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="6"
                                                Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                            </Border>

                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ButtonBorder"
                                                    Property="Background"
                                                    Value="#202124"/>
                                                </Trigger>

                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="#2A2B2E"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>

                        <TextBlock Text="Playlist"
                           FontSize="25"
                           Foreground="White"
                           FontWeight="ExtraBold"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>
                    </Button>

                    <!-- Add button -->
                    <Button Name="AddAlbum"
                        Click="AddAlbum_Click"
                        Cursor="Hand"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="10,4"
                        MinWidth="58"
                        Height="40"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center">

                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>

                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="ButtonBorder"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="6"
                                                Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                            </Border>

                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ButtonBorder"
                                                        Property="Background"
                                                        Value="#202124"/>
                                                </Trigger>

                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="ButtonBorder"
                                                        Property="Background"
                                                        Value="#2A2B2E"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>

                        <TextBlock Text="Add"
                           FontSize="25"
                           Foreground="White"
                           FontWeight="ExtraBold"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>
                    </Button>

                    <!-- Shuffle current album/playlist -->
                    <Button Name="ShuffleButton"
                        Width="40"
                        Height="40"
                        Padding="8"
                        Margin="0,0,8,0"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="ShuffleButton_Click">

                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>

                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="ButtonBorder"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="6"
                                                Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                VerticalAlignment="Center"/>
                                            </Border>

                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ButtonBorder"
                                                    Property="Background"
                                                    Value="#202124"/>
                                                </Trigger>

                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="ButtonBorder"
                                                    Property="Background"
                                                    Value="#2A2B2E"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>

                        <Image Name="ShuffleIcon"
                       Source="/assets/icons/shuffle_unselected.png"
                       Stretch="Uniform"/>
                    </Button>

                    <!-- Liked-only toggle -->
                    <Button Name="LikedOnlyButton"
                        Width="40"
                        Height="40"
                        Padding="8"
                        Margin="0,0,8,0"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="LikedOnlyButton_Click">

                        <Button.ToolTip>
                            <ToolTip Background="#202124"
                             Foreground="White"
                             BorderBrush="Transparent"
                             Padding="8,4"
                             FontSize="12">
                            </ToolTip>
                        </Button.ToolTip>

                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>

                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="ButtonBorder"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="6"
                                            Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                                            </Border>

                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ButtonBorder"
                                    Property="Background"
                                    Value="#202124"/>
                                                </Trigger>

                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="ButtonBorder"
                                    Property="Background"
                                    Value="#2A2B2E"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>

                        <Image Name="LikedOnlyIcon"
                           Source="/assets/icons/heart_hollow.png"
                           Stretch="Uniform"/>
                    </Button>

                </StackPanel>
            </Grid>

            <!-- Albums -->
            <ScrollViewer Grid.Row="1" Background="Transparent"
              VerticalScrollBarVisibility="Auto"
              Padding="0,0,4,0"
              PreviewMouseWheel="AlbumsScrollViewer_PreviewMouseWheel"
              HorizontalScrollBarVisibility="Disabled">

                <WrapPanel Name="AlbumsPanel"
                   Background="Transparent"
                   Margin="8"
                   ItemWidth="128"
                   ItemHeight="128"
                   HorizontalAlignment="Center"/>

            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
