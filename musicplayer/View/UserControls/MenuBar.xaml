<UserControl x:Class="musicplayer.View.UserControls.MenuBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:musicplayer.View.UserControls"
             mc:Ignorable="d"
             Height="40"
             d:DesignHeight="40"
             d:DesignWidth="800">

    <UserControl.Resources>
        <Style x:Key="WindowButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder"
                                    Property="Background"
                                    Value="#202124"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder"
                                    Property="Background"
                                    Value="#2A2B2E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="Transparent"
          Height="40"
          PreviewMouseLeftButtonDown="Grid_MouseLeftButtonDown">

        <!-- App icon, top left -->
        <Border Width="40"
                Height="40"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Background="Transparent"
                Padding="8">

            <Image Source="/assets/icons/mlogoround.ico"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
        </Border>

        <!-- Application Buttons -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    Margin="0">

            <Button Name="btnMinimize"
                    Width="40"
                    Height="40"
                    Margin="0"
                    Padding="0"
                    BorderThickness="0"
                    Content="-"
                    FontSize="16"
                    FontWeight="ExtraBold"
                    Foreground="White"
                    Style="{StaticResource WindowButtonStyle}"
                    Click="btnMinimize_Click"/>

            <Button Name="btnMaximize"
                    Width="40"
                    Height="40"
                    Margin="0"
                    Padding="0"
                    BorderThickness="0"
                    Content="🗖"
                    FontSize="14"
                    FontWeight="ExtraBold"
                    Foreground="White"
                    Style="{StaticResource WindowButtonStyle}"
                    Click="btnMaximize_Click"/>

            <Button Name="btnClose"
                    Width="40"
                    Height="40"
                    Margin="0"
                    Padding="0"
                    BorderThickness="0"
                    Content="X"
                    FontSize="14"
                    FontWeight="ExtraBold"
                    Foreground="White"
                    Style="{StaticResource WindowButtonStyle}"
                    Click="btnClose_Click"/>

        </StackPanel>
    </Grid>
</UserControl>